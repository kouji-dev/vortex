# Local: matches docker-compose.yml in this repo (Compose project `local-dev`).

# Reference: ../kouji-factory/docker-compose.yml and apps/api/.env.example (same URL shape).

# Host ports 5434 / 6380 avoid clashing with kouji-factory (5433 / 6379) when both run.



DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5434/ai_portal



API_HOST=0.0.0.0

API_PORT=8000

CORS_ORIGINS=http://localhost:5173



DEV_BEARER_TOKEN=devtoken

DEV_SEED_USER_EMAIL=dev@localhost



# auth_mode=dev (default) | entra — see docs/superpowers/specs/2026-03-22-auth-entra-design.md

AUTH_MODE=dev

ENTRA_TENANT_ID=

ENTRA_API_AUDIENCE=

# Chat LLM: CHAT_PROVIDER=openai (api.openai.com) | azure_openai
CHAT_PROVIDER=openai
CHAT_MODEL=o3-mini
# When creating a conversation without a model: first active Sonnet row in catalog_models
# Fallback when catalog has no preferred row (seed prefers anthropic-claude-haiku-4-5).
CHAT_DEFAULT_LITELLM_MODEL=claude-haiku-4-5-20251001

# Backend Settings (LiteLLM)
# — OpenAI / Azure OpenAI / OpenAI-compatible proxy: set LLM_API_BASE + LLM_API_KEY (required
#   for gpt-* and azure/* catalog models, and for embeddings with the default embedding model).
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=

# — Anthropic Claude (catalog ids like claude-3-5-sonnet-20241022): set ANTHROPIC_API_KEY, or
#   put the same secret in LLM_API_KEY if you only use Claude and skip a separate OpenAI key.
ANTHROPIC_API_KEY=

# Example LiteLLM proxy (host): LLM_API_BASE=http://127.0.0.1:4000/v1



EMBEDDING_MODEL=text-embedding-3-small



# HMAC pepper for portal API keys (Bearer tokens prefixed with aip_).
# Required when AUTH_MODE=entra (API will not start with an empty/whitespace value).
# Optional in AUTH_MODE=dev (empty falls back to dev-only hashing).

PORTAL_API_KEY_PEPPER=



# Upload directory for document ingest (relative to backend cwd).

UPLOAD_DIR=data/uploads



# Optional Langfuse (Chunk 6); leave empty to disable.

LANGFUSE_PUBLIC_KEY=

LANGFUSE_SECRET_KEY=

LANGFUSE_HOST=https://cloud.langfuse.com



# Frontend (optional): copy frontend/.env.example → frontend/.env — VITE_API_URL, VITE_AUTH_MODE, VITE_DEV_BEARER_TOKEN, VITE_ENTRA_*.


