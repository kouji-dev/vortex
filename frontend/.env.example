# Optional. Omit in local dev to use the Vite proxy (/api and /health → FastAPI, default
# http://127.0.0.1:8000). Set to your API origin for direct calls (must match CORS).
# No `/api` suffix — the app uses `${VITE_API_URL}/api/...`.
# VITE_API_URL=http://127.0.0.1:8000

# dev (default): send bearer token below on API calls. entra: MSAL sign-in + API scope.
# Must match repo root .env AUTH_MODE (dev + devtoken vs entra + JWT).
VITE_AUTH_MODE=dev

# Must match backend DEV_BEARER_TOKEN when VITE_AUTH_MODE=dev (default devtoken).
VITE_DEV_BEARER_TOKEN=devtoken

# When VITE_AUTH_MODE=entra — SPA app registration + API scope (full string, e.g. api://xxx/access_as_user).
VITE_ENTRA_SPA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_API_SCOPE=
