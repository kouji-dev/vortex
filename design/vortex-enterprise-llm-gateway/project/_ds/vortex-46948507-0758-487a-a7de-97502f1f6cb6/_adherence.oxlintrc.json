{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/chat/**",
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "components/surfaces/**",
              "ui_kits/app/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|IBM Plex Sans|IBM Plex Mono|IBM Plex Serif))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, IBM Plex Sans, IBM Plex Mono, IBM Plex Serif."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|gradient|iconLeft|iconRight|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, gradient, iconLeft, iconRight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:hover|glow|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: hover, glow."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|who|time|grounded|state|children|className|style|key|ref|className|style|children)$/]",
        "message": "<ChatMessage> doesn't accept that prop. Declared props: role, who, time, grounded, state, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:user|ai)$/]",
        "message": "<ChatMessage> role must be one of 'user' | 'ai'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:idle|loading|streaming|thinking|error)$/]",
        "message": "<ChatMessage> state must be one of 'idle' | 'loading' | 'streaming' | 'thinking' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComposerModel'] > JSXAttribute > JSXIdentifier[name!=/^(?:provider|name|effort|key|ref|className|style|children)$/]",
        "message": "<ComposerModel> doesn't accept that prop. Declared props: provider, name, effort."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComposerModel'] > JSXAttribute[name.name='provider'] > Literal[value!=/^(?:anthropic|openai|google|mistral)$/]",
        "message": "<ComposerModel> provider must be one of 'anthropic' | 'openai' | 'google' | 'mistral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Column'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|align|mono|width|key|ref|className|style|children)$/]",
        "message": "<Column> doesn't accept that prop. Declared props: label, align, mono, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='Column'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right|center)$/]",
        "message": "<Column> align must be one of 'left' | 'right' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|className|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|htmlFor|children|style|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, hint, htmlFor, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProviderMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:provider|size|key|ref|className|style|children)$/]",
        "message": "<ProviderMark> doesn't accept that prop. Declared props: provider, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='PrismLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|size|title|className|style|key|ref|className|style|children)$/]",
        "message": "<PrismLogo> doesn't accept that prop. Declared props: state, size, title, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:seed|color|width|height|className|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: seed, color, width, height, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: status, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|size|className|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, size, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Switch> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|count|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|className|style|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: variant, size, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gradient|core|ink)$/]",
        "message": "<Wordmark> variant must be one of 'gradient' | 'core' | 'ink'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
