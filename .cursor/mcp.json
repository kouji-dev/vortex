{
  "mcpServers": {
    "task-manager": {
      "url": "http://localhost:3847/mcp"
    },
    "youtube-transcript-fabriqa": {
      "command": "npx",
      "args": [
        "-y",
        "@fabriqa.ai/youtube-transcript-mcp@latest"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics"
      ]
    }
  }
}