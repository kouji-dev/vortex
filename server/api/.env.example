# ai-portal backend — example env. Copy to .env and fill placeholders.
# .env is gitignored.

# ── Database ────────────────────────────────────────────────────────────
# Dev DB:  postgresql+psycopg://postgres:postgres@127.0.0.1:5434/ai_portal
# E2E DB:  postgresql+psycopg://postgres:postgres@127.0.0.1:5435/ai_portal_e2e
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5434/ai_portal

# ── Server ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ── Auth / deployment ───────────────────────────────────────────────────
# saas | selfhosted   (both require SECRET_KEY)
DEPLOYMENT_MODE=saas
# Required for JWT signing.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Entra (legacy; unused by default OIDC path)
ENTRA_TENANT_ID=
ENTRA_API_AUDIENCE=
ENTRA_DEBUG_JWT=false
# Required HMAC pepper when AUTH_MODE=entra
PORTAL_API_KEY_PEPPER=

# ── Envelope encryption (Fernet keys) ───────────────────────────────────
# Generate each with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AUDIT_KEK=
MEMORY_KEK=

# ── Observability ───────────────────────────────────────────────────────
OTEL_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ── Catalog ─────────────────────────────────────────────────────────────
# Skip background catalog refresh + provider health probes.
CATALOG_SYNC_ENABLED=false

# ── Gateway (dev / test) ────────────────────────────────────────────────
# Binds FakeProvider to /v1/chat/completions for smoke tests + dev without
# real provider keys. NEVER set in production.
GATEWAY_USE_FAKE_PROVIDER=false

# ── LLM providers (set what you use) ────────────────────────────────────
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
CHAT_DEFAULT_API_MODEL=gemini-2.5-flash-lite

# ── Embeddings ──────────────────────────────────────────────────────────
VOYAGE_API_KEY=
EMBEDDING_MODEL=

# ── Web search + fetch tools ────────────────────────────────────────────
SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=
SERPER_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
JINA_API_KEY=
USER_SEARCH_COUNTRY=FR

# ── Notify (login alerts, invites, verification, password reset) ───────
# Prefer SendGrid when set; falls back to SMTP otherwise.
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.com

# ── Billing (optional) ──────────────────────────────────────────────────
# BILLING_PROVIDER=stripe to enable Stripe; leave unset for noop.
BILLING_PROVIDER=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Background queue (optional) ─────────────────────────────────────────
# Leave empty to run ingest in-process.
REDIS_URL=

# ── Uploads + ingest ────────────────────────────────────────────────────
UPLOAD_DIR=data/uploads
KB_MAX_FILE_SIZE_MB=500
INGEST_COMMIT_BATCH_SIZE=100
INGEST_EMBED_BATCH_SIZE=128

# ── RAG retrieval ───────────────────────────────────────────────────────
RAG_MAX_TOP_K=30
RAG_MIN_TOP_K=8
RAG_SIMILARITY_THRESHOLD=0.3
RAG_MAX_TOOL_ITERATIONS=1

# ── Conversation memory ─────────────────────────────────────────────────
CONVERSATION_BASE_WINDOW_SIZE=30
CONVERSATION_SUMMARY_INTERVAL=10
CONVERSATION_INACTIVITY_SUMMARY_HOURS=1

# ── Enterprise flags ────────────────────────────────────────────────────
AUDIT_ENABLED=true
RETENTION_ENABLED=false
RBAC_DEFAULT_POLICY=allow

# ── Native provider SDKs (default on) ───────────────────────────────────
USE_NATIVE_ANTHROPIC=true
USE_NATIVE_GEMINI=true

# ── E2E seed flags (set by scripts/e2e-up.sh — do NOT enable in prod) ──
# E2E_ENABLE_RAG_SEED=1
# E2E_ENABLE_CHAT_MESSAGES_SEED=1
