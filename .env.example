# Local: matches docker-compose.yml in this repo (Compose project `local-dev`).
# Reference: ../kouji-factory/docker-compose.yml and apps/api/.env.example (same URL shape).
# Host ports 5434 / 6380 avoid clashing with kouji-factory (5433 / 6379) when both run.

DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5434/ai_portal
REDIS_URL=redis://127.0.0.1:6380/0

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

DEV_BEARER_TOKEN=devtoken
DEV_SEED_USER_EMAIL=dev@localhost

OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Upload directory for document ingest (relative to backend cwd).
UPLOAD_DIR=data/uploads

# Optional Langfuse (Chunk 6); leave empty to disable.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Frontend (optional): copy frontend/.env.example → frontend/.env — VITE_API_URL, VITE_DEV_TOKEN.

# Azure: inject via Key Vault / App Settings / managed identity; never commit real secrets.
