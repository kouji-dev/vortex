# ─────────────────────────────────────────────────────────────
# Vortex — environment (single .env for all apps; SaaS + self-host)
# Copy to .env and fill. Config is layered: defaults → env → org DB.
# ─────────────────────────────────────────────────────────────

# Deployment
NODE_ENV=development
TENANCY_MODE=single            # single (on-prem, one org) | multi (SaaS, many orgs)
API_PORT=8080
WEB_ORIGIN=http://localhost:4200
PLATFORM_ORIGIN=http://localhost:4300

# Database (Postgres) — docker-compose maps 5433
# DATABASE_URL = owner/superuser, used for migrations + seed + RLS setup
DATABASE_URL=postgres://vortex:vortex@localhost:5433/vortex
# APP_DATABASE_URL = non-superuser role the app runs as, so RLS is enforced
APP_DATABASE_URL=postgres://vortex_app:vortex_app@localhost:5433/vortex

# Redis — docker-compose maps 6380
REDIS_URL=redis://localhost:6380

# Auth (better-auth)
BETTER_AUTH_SECRET=dev-change-me-please-32chars-minimum
BETTER_AUTH_URL=http://localhost:8080

# Social auth (OAuth) — optional; a provider is enabled when both id + secret are set.
# Callback URLs to register: {BETTER_AUTH_URL}/api/auth/callback/{github|google}
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption — per-org key derivation root (32-byte base64)
ENCRYPTION_KEY=dev-base64-32byte-key-change-me

# API-key hashing pepper — HMAC secret for virtual-key hashes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Must be identical across all API replicas; rotating it invalidates every issued key.
API_KEY_PEPPER=dev-pepper-change-me-32bytes-min

# First-run seed (single mode / first tenant)
SEED_ORG_NAME=Acme
SEED_ADMIN_EMAIL=admin@acme.test
SEED_ADMIN_PASSWORD=changeme123

# ── Providers: code defines the full catalog; env activates + overrides URLs ──
# Comma-separated enabled providers (empty = all in the code catalog)
ENABLED_PROVIDERS=openai,anthropic,google
# Per-provider credentials + optional base-URL overrides (BYOK overrides these at runtime)
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
GOOGLE_API_KEY=
GOOGLE_BASE_URL=
# Azure OpenAI (deployment-specific; deployment defaults to the model name)
AZURE_OPENAI_RESOURCE=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_API_KEY=
# AWS Bedrock (bearer API key — no SigV4). Uses the OpenAI-compat path.
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_BASE_URL=
AWS_BEDROCK_API_KEY=
# Google Vertex (project + region; OAuth bearer token or api-key via ?key=)
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_REGION=global
GOOGLE_VERTEX_API_KEY=
# OpenAI-compatible inference providers (set a key to enable; base URL optional).
# Route with a provider prefix, e.g. model="groq/llama-3.3-70b-versatile".
GROQ_API_KEY=
GROQ_BASE_URL=
MISTRAL_API_KEY=
MISTRAL_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
XAI_API_KEY=
XAI_BASE_URL=
TOGETHER_API_KEY=
TOGETHER_BASE_URL=
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=

# ── Stripe (SaaS / multi mode only) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_RETURN_URL=http://localhost:4200/billing
