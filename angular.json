{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm"
  },
  "newProjectRoot": "apps",
  "projects": {
    "web": {
      "projectType": "application",
      "schematics": {},
      "root": "apps/web",
      "sourceRoot": "apps/web/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/web",
            "browser": "apps/web/src/main.ts",
            "index": "apps/web/src/index.html",
            "tsConfig": "apps/web/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/web/public"
              }
            ],
            "styles": [
              "packages/design-system/vortex.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4200,
            "host": "localhost",
            "proxyConfig": "apps/web/proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "web:build:production"
            },
            "development": {
              "buildTarget": "web:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "platform": {
      "projectType": "application",
      "schematics": {},
      "root": "apps/platform",
      "sourceRoot": "apps/platform/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/platform",
            "browser": "apps/platform/src/main.ts",
            "index": "apps/platform/src/index.html",
            "tsConfig": "apps/platform/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/platform/public"
              }
            ],
            "styles": [
              "packages/design-system/vortex.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4300,
            "host": "localhost",
            "proxyConfig": "apps/platform/proxy.conf.json"
          },
          "configurations": {
            "production": {
              "buildTarget": "platform:build:production"
            },
            "development": {
              "buildTarget": "platform:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "landing": {
      "projectType": "application",
      "schematics": {},
      "root": "apps/landing",
      "sourceRoot": "apps/landing/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/landing",
            "browser": "apps/landing/src/main.ts",
            "index": "apps/landing/src/index.html",
            "tsConfig": "apps/landing/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "apps/landing/public"
              }
            ],
            "styles": [
              "packages/design-system/vortex.css",
              "apps/landing/src/styles.css",
              "apps/landing/src/catalog.css"
            ],
            "server": "apps/landing/src/main.server.ts",
            "outputMode": "server",
            "ssr": {
              "entry": "apps/landing/src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2MB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "apps/landing/src/environments/environment.ts",
                  "with": "apps/landing/src/environments/environment.prod.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4400,
            "host": "localhost"
          },
          "configurations": {
            "production": {
              "buildTarget": "landing:build:production"
            },
            "development": {
              "buildTarget": "landing:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
